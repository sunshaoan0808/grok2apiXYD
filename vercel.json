{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "fastapi",
  "env": {
    "LOG_LEVEL": "INFO",
    "LOG_FILE_ENABLED": "false",
    "DATA_DIR": "/tmp/data"
  },
  "rewrites": [
    {
      "source": "/js/:path*",
      "destination": "/app/static/public/js/:path*"
    },
    {
      "source": "/css/:path*",
      "destination": "/app/static/public/css/:path*"
    }
  ]
}
